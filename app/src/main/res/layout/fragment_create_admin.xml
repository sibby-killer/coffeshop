<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/primary"
        android:padding="20dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Create Admin"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:fontFamily="@font/poppins_regular" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintBottom_toBottomOf="parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/grid_bg"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Create a new admin account"
                    android:textSize="14sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginBottom="16dp" />

                <EditText
                    android:id="@+id/admin_fullname"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="Full Name"
                    android:textSize="15sp"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:paddingHorizontal="14dp"
                    android:background="@drawable/edit_text_bg" />

                <EditText
                    android:id="@+id/admin_email"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="Email"
                    android:inputType="textEmailAddress"
                    android:textSize="15sp"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:paddingHorizontal="14dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/edit_text_bg" />

                <EditText
                    android:id="@+id/admin_phone"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="Phone"
                    android:inputType="phone"
                    android:textSize="15sp"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:paddingHorizontal="14dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/edit_text_bg" />

                <EditText
                    android:id="@+id/admin_password"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="Password (min 6 chars)"
                    android:inputType="textPassword"
                    android:textSize="15sp"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:paddingHorizontal="14dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/edit_text_bg" />

                <Button
                    android:id="@+id/create_admin_btn"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Create Admin Account"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_on_primary"
                    android:background="@drawable/btn_bg"
                    android:layout_marginTop="20dp" />

                <TextView
                    android:id="@+id/result_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/success"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
