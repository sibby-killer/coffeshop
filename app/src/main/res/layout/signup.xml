<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_dark">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/coffe" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#20FFFFFF" />

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:navigationIcon="@drawable/ic_back"
                app:navigationIconTint="@color/white"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

        </com.google.android.material.appbar.AppBarLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            app:layout_behavior="@string/appbar_scrolling_view_behavior"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create Account"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:fontFamily="@font/poppins_regular" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Join us and start ordering"
                    android:textSize="14sp"
                    android:textColor="#B0A090"
                    android:fontFamily="@font/poppins_regular"
                    android:layout_marginTop="4dp" />

                <!-- Form Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/grid_bg"
                    android:padding="20dp"
                    android:layout_marginTop="20dp">

                    <!-- Role Selector -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="I want to"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/role_spinner"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/edit_text_bg"
                        android:padding="8dp"
                        android:layout_marginTop="6dp" />

                    <!-- Common Fields -->
                    <EditText
                        android:id="@+id/full_name_input"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Full Name"
                        android:textSize="15sp"
                        android:textColorHint="@color/text_hint"
                        android:textColor="@color/text_primary"
                        android:paddingHorizontal="16dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/edit_text_bg" />

                    <EditText
                        android:id="@+id/email_input"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Email"
                        android:inputType="textEmailAddress"
                        android:textSize="15sp"
                        android:textColorHint="@color/text_hint"
                        android:textColor="@color/text_primary"
                        android:paddingHorizontal="16dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/edit_text_bg" />

                    <EditText
                        android:id="@+id/phone_input"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Phone: 2547XXXXXXXX (12 digits)"
                        android:inputType="phone"
                        android:textSize="15sp"
                        android:textColorHint="@color/text_hint"
                        android:textColor="@color/text_primary"
                        android:paddingHorizontal="16dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/edit_text_bg"
                        android:maxLength="12" />

                    <TextView
                        android:id="@+id/phone_error"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="12sp"
                        android:textColor="#FF5252"
                        android:layout_marginTop="4dp"
                        android:visibility="gone" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp">

                        <EditText
                            android:id="@+id/password_input"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="Password (min 6 chars)"
                            android:inputType="textPassword"
                            android:textSize="15sp"
                            android:textColorHint="@color/text_hint"
                            android:textColor="@color/text_primary"
                            android:paddingHorizontal="16dp"
                            android:paddingEnd="48dp"
                            android:background="@drawable/edit_text_bg" />

                        <ImageView
                            android:id="@+id/toggle_password"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_eye_off"
                            android:padding="12dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:layout_gravity="end" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/password_strength"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="12sp"
                        android:textStyle="italic"
                        android:textColor="#FF8F00"
                        android:layout_marginTop="4dp"
                        android:visibility="gone" />

                    <!-- Shop Owner Extra Fields -->
                    <LinearLayout
                        android:id="@+id/shop_owner_fields"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#E0D5CC"
                            android:layout_marginVertical="16dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Shop Details"
                            android:textColor="@color/primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins_regular" />

                        <EditText
                            android:id="@+id/shop_name_input"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="Shop Name"
                            android:textSize="15sp"
                            android:textColorHint="@color/text_hint"
                            android:textColor="@color/text_primary"
                            android:paddingHorizontal="16dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/edit_text_bg" />

                        <EditText
                            android:id="@+id/shop_description_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Shop Description"
                            android:inputType="textMultiLine"
                            android:minLines="2"
                            android:textSize="15sp"
                            android:textColorHint="@color/text_hint"
                            android:textColor="@color/text_primary"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="12dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/edit_text_bg" />

                        <EditText
                            android:id="@+id/shop_location_input"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="Location / Address"
                            android:textSize="15sp"
                            android:textColorHint="@color/text_hint"
                            android:textColor="@color/text_primary"
                            android:paddingHorizontal="16dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/edit_text_bg" />

                        <EditText
                            android:id="@+id/shop_phone_input"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="Shop Phone (optional)"
                            android:inputType="phone"
                            android:textSize="15sp"
                            android:textColorHint="@color/text_hint"
                            android:textColor="@color/text_primary"
                            android:paddingHorizontal="16dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/edit_text_bg" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/signup_button"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Create Account"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_on_primary"
                        android:background="@drawable/btn_bg"
                        android:layout_marginTop="20dp" />

                    <TextView
                        android:id="@+id/login_link"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Already have an account? Sign In"
                        android:textColor="@color/primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_gravity="center_horizontal" />

                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</FrameLayout>
