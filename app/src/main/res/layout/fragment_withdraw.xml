<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/primary"
        android:padding="20dp"
        android:paddingTop="32dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_profile"
            android:tint="@color/white"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Withdraw Funds"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:fontFamily="@font/poppins_regular" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_gravity="center"
        android:layout_marginTop="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Balance Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/primary"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Available Balance"
                        android:textSize="14sp"
                        android:textColor="@color/white" />

                    <TextView
                        android:id="@+id/balance_amount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KES 0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Withdrawal Form -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Withdrawal Request"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <EditText
                        android:id="@+id/full_name_input"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:hint="Full Name"
                        android:textSize="14sp"
                        android:textColorHint="@color/text_hint"
                        android:textColor="@color/text_primary"
                        android:paddingHorizontal="14dp"
                        android:background="@drawable/edit_text_bg"
                        android:layout_marginTop="12dp" />

                    <Spinner
                        android:id="@+id/payment_method_spinner"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/edit_text_bg"
                        android:layout_marginTop="8dp"
                        android:paddingHorizontal="10dp" />

                    <EditText
                        android:id="@+id/account_number_input"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:hint="Phone / Account Number"
                        android:inputType="phone"
                        android:textSize="14sp"
                        android:textColorHint="@color/text_hint"
                        android:textColor="@color/text_primary"
                        android:paddingHorizontal="14dp"
                        android:background="@drawable/edit_text_bg"
                        android:layout_marginTop="8dp" />

                    <EditText
                        android:id="@+id/amount_input"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:hint="Amount (KES)"
                        android:inputType="numberDecimal"
                        android:textSize="14sp"
                        android:textColorHint="@color/text_hint"
                        android:textColor="@color/text_primary"
                        android:paddingHorizontal="14dp"
                        android:background="@drawable/edit_text_bg"
                        android:layout_marginTop="8dp" />

                    <Button
                        android:id="@+id/submit_withdrawal_button"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="Submit Withdrawal"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_on_primary"
                        android:background="@drawable/btn_bg"
                        android:layout_marginTop="14dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Withdrawal History -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Withdrawal History"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/empty_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No withdrawal history"
                android:textSize="14sp"
                android:textColor="@color/text_muted"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/history_recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
